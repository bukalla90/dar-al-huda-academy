generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  student      Student?
  teacher      Teacher?

  @@index([username])
  @@index([role])
}

model Teacher {
  id        String            @id @default(cuid())
  userId    String            @unique
  fullName  String
  email     String            @unique
  phone     String
  bio       String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  salary    Float?
  sessions  ClassSession[]
  materials Material[]
  students  Student[]
  progress  StudentProgress[]
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id              String            @id @default(cuid())
  userId          String            @unique
  teacherId       String?
  fullName        String
  age             Int
  country         String
  phone           String
  scheduleTime    String?
  courseType      CourseType
  parentName      String
  parentPhone     String
  parentWhatsapp  String
  relationship    String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attendances     Attendance[]
  materials       Material[]
  payments        Payment[]
  sessionStudents SessionStudent[]
  teacher         Teacher?          @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  progress        StudentProgress[]
}

model Application {
  id            String            @id @default(cuid())
  fullName      String
  age           Int
  country       String
  phone         String
  email         String
  desiredCourse CourseType
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model ClassSession {
  id              String           @id @default(cuid())
  teacherId       String
  meetingUrl      String
  scheduledAt     DateTime
  status          String           @default("SCHEDULED")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  attendances     Attendance[]
  teacher         Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sessionStudents SessionStudent[]
}

model SessionStudent {
  id        String       @id @default(cuid())
  sessionId String
  studentId String
  joinedAt  DateTime?
  leftAt    DateTime?
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  sessionId String
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  session   ClassSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([sessionId])
}

model Material {
  id         String       @id @default(cuid())
  title      String
  fileUrl    String
  type       MaterialType
  courseType CourseType?  // ADDED: For course-specific materials (null = all courses)
  teacherId  String
  studentId  String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  student    Student?     @relation(fields: [studentId], references: [id], onDelete: SetNull)
  teacher    Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model StudentProgress {
  id        String   @id @default(cuid())
  studentId String
  teacherId String
  surah     String
  ayahFrom  Int
  ayahTo    Int
  notes     String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([surah])
}

model Payment {
  id        String        @id @default(cuid())
  studentId String
  amount    Float
  currency  String        @default("USD")
  month     String
  status    PaymentStatus
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([month])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  type      String
  title     String
  message   String
  username  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum CourseType {
  HIFZ
  TAJWEED
  NAZIRAH
  MURAJAAH
  AQIDAH
  FIQH
  HADITH
  ARABIC_LANGUAGE
  ISLAMIC_MANNERS
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
  OVERDUE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MaterialType {
  PDF
  AUDIO
  IMAGE
}